# =================================================================
# RAY environment variables
# =================================================================
# Copy this file to `.env.local` for local development, or set these
# values in your cloud provider's environment-variables UI for prod.
# =================================================================

# --- Neon Postgres ---
# The app will auto-create all tables and seed three demo accounts
# (admin / john.smith / executive) on first start.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# --- Gmail SMTP for OTP delivery ---
# 1. Sign in to the Gmail account you want to send from.
# 2. Enable 2-Step Verification at https://myaccount.google.com/security
# 3. Generate an App Password at https://myaccount.google.com/apppasswords
# 4. Paste the 16-character code into EMAIL_PASSWORD below (spaces are stripped).
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-gmail-app-password

# --- Google Drive (optional but recommended) ---
# When both of these are set, all knowledge-base uploads go to Drive.
# When either is missing, the app falls back to local-disk storage at
# `./uploads/`. See SETUP-DRIVE.md for the full walkthrough.
#
# DRIVE_ROOT_FOLDER_ID is the Drive folder id under which RAY will create
# `admin/`, `employees/`, `executives/` subfolders. The service account
# must have Editor access to this folder.
DRIVE_ROOT_FOLDER_ID=

# Provide credentials either as inline JSON (one line) ...
GOOGLE_SERVICE_ACCOUNT_JSON=
# ... or as a path to a JSON key file on disk.
GOOGLE_SERVICE_ACCOUNT_FILE=

# --- Email mascot rendering ---
# Public base URL of your deployment. Used to build absolute image URLs in
# transactional emails so the RAY mascot renders reliably in every webmail
# client. Examples:
#   Local dev:   leave UNSET (the email falls back to inline CID attachment)
#   Vercel:      https://your-app.vercel.app
#   Custom:      https://app.vexar.tech
PUBLIC_BASE_URL=
